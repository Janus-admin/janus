{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT w.id, w.name, w.slug, w.created_at,\n                   COUNT(wm.id) as \"member_count!\"\n            FROM workspaces w\n            LEFT JOIN workspace_members wm ON wm.workspace_id = w.id\n            GROUP BY w.id, w.name, w.slug, w.created_at\n            ORDER BY w.created_at\n            ",
