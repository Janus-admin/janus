{
  "_comment": "Synthetic Portkey workspace export. Real Portkey exports use the same shape (virtual_keys + configs with strategies + cache blocks).",
  "virtual_keys": [
    {
      "name": "prod-openai-key",
      "provider": "openai",
      "api_key": "sk-portkey-openai"
    },
    {
      "name": "prod-anthropic-key",
      "provider": "anthropic",
      "api_key": "sk-ant-portkey"
    }
  ],
  "configs": [
    {
      "name": "fallback-config",
      "strategy": {
        "mode": "fallback",
        "targets": [
          {
            "provider": "openai",
            "api_key": "sk-portkey-target-openai",
            "weight": 1.0
          },
          {
            "provider": "anthropic",
            "api_key": "sk-ant-portkey-target",
            "weight": 1.0
          }
        ]
      },
      "cache": {
        "mode": "semantic",
        "similarity_threshold": 0.88
      }
    },
    {
      "name": "loadbalance-config",
      "strategy": {
        "mode": "loadbalance",
        "targets": [
          {
            "provider": "groq",
            "api_key": "gsk-portkey-target"
          },
          {
            "provider": "deepseek",
            "api_key": "sk-ds-portkey-target"
          }
        ]
      }
    }
  ]
}
