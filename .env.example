# ── Required secrets ────────────────────────────────────────────────────────────
# Generate each with: openssl rand -base64 32

JWT_SECRET=
ENCRYPTION_KEY=
POSTGRES_PASSWORD=janus_dev

# ── Provider API keys ─────────────────────────────────────────────────────────────
# Add at least one. Leave the others blank to disable that provider.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# ── AWS Bedrock (optional) ────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── Logging ──────────────────────────────────────────────────────────────────────
RUST_LOG=info
