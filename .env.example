# ── Required secrets ────────────────────────────────────────────────────────────
# Generate each with: openssl rand -base64 32

JWT_SECRET=
ENCRYPTION_KEY=
POSTGRES_PASSWORD=janus_dev

# ── Provider API keys ─────────────────────────────────────────────────────────────
# Add at least one. Leave the others blank to disable that provider.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# ── AWS Bedrock (optional) ────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── Logging ──────────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── DB connection (Docker Compose uses 'db' as the hostname; override if you run
# PostgreSQL on the host or elsewhere) ────────────────────────────────────────────
# DATABASE_URL=postgres://janus:janus_dev@localhost:5432/janus

# ── Audit-log task admission control ─────────────────────────────────────────────
# Each completed gateway request spawns 1–4 fire-and-forget DB writes (request row,
# daily cost upsert, budget add, last-used touch). At sustained throughput beyond
# what PostgreSQL can absorb (>~10k inserts/sec), these tasks queue up and consume
# unbounded memory. AUDIT_INFLIGHT_MAX caps the in-flight set — drops past this
# bound are counted in the Prometheus metric `janus_audit_dropped_total`. Default
# 2000 keeps audit memory under ~2 MB regardless of incoming rate.
# AUDIT_INFLIGHT_MAX=2000
